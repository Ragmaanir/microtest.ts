{
  "name": "microtest.ts",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "microtest": "./dist/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "tsx src/cli.ts test",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^24.0.0",
    "tundra": "github:Ragmaanir/tundra",
    "typescript": "^5.8"
  }
}
